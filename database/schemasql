CREATE TABLE tutor_availability (
    id SERIAL PRIMARY KEY,
    tutor_id INTEGER NOT NULL,
    day_of_week INTEGER NOT NULL,
    start_time TIME NOT NULL,
    end_time TIME NOT NULL,
    max_capacity INTEGER DEFAULT 5,
    available_slots INTEGER DEFAULT 5,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CHECK (day_of_week BETWEEN 1 AND 7),
    CHECK (start_time < end_time),
    CHECK (max_capacity > 0),
    UNIQUE(tutor_id, day_of_week, start_time, end_time)
);

CREATE TABLE tutor_subject (
    id SERIAL PRIMARY KEY,
    tutor_id INTEGER NOT NULL,
    subject_id INTEGER NOT NULL,
    experience_level VARCHAR(50),
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(tutor_id, subject_id)
);

CREATE INDEX idx_tutor_availability_tutor ON tutor_availability(tutor_id, day_of_week);
CREATE INDEX idx_tutor_availability_active ON tutor_availability(is_active);
CREATE INDEX idx_tutor_subject_tutor ON tutor_subject(tutor_id);
CREATE INDEX idx_tutor_subject_subject ON tutor_subject(subject_id);

CREATE VIEW vw_complete_availability AS
SELECT 
    ta.id,
    ta.tutor_id,
    u.first_name as tutor_first_name,
    u.last_name as tutor_last_name,
    ta.day_of_week,
    ta.start_time,
    ta.end_time,
    ta.max_capacity,
    ta.available_slots,
    ta.is_active,
    ts.subject_id,
    s.name as subject_name
FROM tutor_availability ta
JOIN users u ON ta.tutor_id = u.id
JOIN tutor_subject ts ON ta.tutor_id = ts.tutor_id
JOIN subjects s ON ts.subject_id = s.id
WHERE ta.is_active = TRUE AND ts.is_active = TRUE;